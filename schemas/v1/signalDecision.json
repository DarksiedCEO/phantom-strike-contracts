{
  "$ref": "#/definitions/signalDecision",
  "definitions": {
    "signalDecision": {
      "type": "object",
      "properties": {
        "signal_id": {
          "type": "string",
          "format": "uuid"
        },
        "baseline_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "confidence_delta": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "updated_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "confidence_band": {
          "type": "string",
          "enum": [
            "low",
            "guarded",
            "elevated",
            "confirmed"
          ]
        },
        "disposition": {
          "type": "string",
          "enum": [
            "promote",
            "hold",
            "suppress",
            "escalate"
          ]
        },
        "reasoning": {
          "type": "string",
          "minLength": 1
        },
        "trace_id": {
          "type": "string",
          "minLength": 8,
          "maxLength": 128
        },
        "correlation_id": {
          "$ref": "#/definitions/signalDecision/properties/signal_id"
        }
      },
      "required": [
        "signal_id",
        "baseline_confidence",
        "confidence_delta",
        "updated_confidence",
        "confidence_band",
        "disposition",
        "reasoning",
        "trace_id",
        "correlation_id"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
