{
  "$ref": "#/definitions/sourceProvenance",
  "definitions": {
    "sourceProvenance": {
      "type": "object",
      "properties": {
        "provenance_id": {
          "type": "string",
          "format": "uuid"
        },
        "signal_id": {
          "$ref": "#/definitions/sourceProvenance/properties/provenance_id"
        },
        "source": {
          "type": "object",
          "properties": {
            "source_id": {
              "$ref": "#/definitions/sourceProvenance/properties/provenance_id"
            },
            "source_type": {
              "type": "string",
              "enum": [
                "osint",
                "internal",
                "partner",
                "human",
                "synthetic"
              ]
            },
            "source_locator": {
              "type": "string",
              "minLength": 1
            },
            "original_url": {
              "type": "string",
              "format": "uri"
            },
            "collection_method": {
              "type": "string",
              "enum": [
                "manual_entry",
                "api_pull",
                "web_scrape",
                "partner_feed",
                "sensor_ingest",
                "analyst_upload"
              ]
            },
            "collected_at": {
              "type": "string",
              "format": "date-time"
            },
            "reliability_tier": {
              "type": "string",
              "enum": [
                "unverified",
                "low",
                "medium",
                "high",
                "trusted"
              ]
            },
            "authenticity_assessment": {
              "type": "string",
              "enum": [
                "unknown",
                "suspected_authentic",
                "verified_authentic",
                "manipulated",
                "spoofed"
              ]
            },
            "ingestion_version": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+(-[\\w.-]+)?$"
            },
            "content_fingerprint": {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{64}$"
            }
          },
          "required": [
            "source_id",
            "source_type",
            "source_locator",
            "collection_method",
            "collected_at",
            "reliability_tier",
            "authenticity_assessment",
            "ingestion_version"
          ],
          "additionalProperties": false
        },
        "observed_at": {
          "$ref": "#/definitions/sourceProvenance/properties/source/properties/collected_at"
        },
        "created_at": {
          "$ref": "#/definitions/sourceProvenance/properties/source/properties/collected_at"
        },
        "updated_at": {
          "$ref": "#/definitions/sourceProvenance/properties/source/properties/collected_at"
        },
        "collector": {
          "$ref": "#/definitions/sourceProvenance/properties/source/properties/source_locator"
        },
        "chain_of_custody": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "stage": {
                "$ref": "#/definitions/sourceProvenance/properties/source/properties/source_locator"
              },
              "actor": {
                "$ref": "#/definitions/sourceProvenance/properties/source/properties/source_locator"
              },
              "occurred_at": {
                "$ref": "#/definitions/sourceProvenance/properties/source/properties/collected_at"
              },
              "note": {
                "$ref": "#/definitions/sourceProvenance/properties/source/properties/source_locator"
              }
            },
            "required": [
              "stage",
              "actor",
              "occurred_at"
            ],
            "additionalProperties": false
          }
        },
        "dedupe_key": {
          "type": "string",
          "minLength": 8,
          "maxLength": 256
        },
        "audit": {
          "type": "object",
          "properties": {
            "schema": {
              "type": "object",
              "properties": {
                "contractVersion": {
                  "type": "string",
                  "const": "v1"
                },
                "schemaName": {
                  "$ref": "#/definitions/sourceProvenance/properties/source/properties/source_locator"
                },
                "schemaRevision": {
                  "type": "integer",
                  "minimum": 0
                },
                "packageVersion": {
                  "type": "string",
                  "pattern": "^\\d+\\.\\d+\\.\\d+(-[\\w.-]+)?$"
                }
              },
              "required": [
                "contractVersion",
                "schemaName",
                "schemaRevision",
                "packageVersion"
              ],
              "additionalProperties": false
            },
            "trace": {
              "type": "object",
              "properties": {
                "request_id": {
                  "$ref": "#/definitions/sourceProvenance/properties/provenance_id"
                },
                "trace_id": {
                  "type": "string",
                  "minLength": 8,
                  "maxLength": 128
                },
                "correlation_id": {
                  "$ref": "#/definitions/sourceProvenance/properties/provenance_id"
                },
                "actor_service": {
                  "type": "string",
                  "enum": [
                    "contracts",
                    "core",
                    "workflows",
                    "intel",
                    "console"
                  ]
                },
                "environment": {
                  "type": "string",
                  "enum": [
                    "local",
                    "dev",
                    "staging",
                    "production"
                  ]
                }
              },
              "required": [
                "request_id",
                "trace_id",
                "correlation_id",
                "actor_service",
                "environment"
              ],
              "additionalProperties": false
            },
            "recorded_at": {
              "$ref": "#/definitions/sourceProvenance/properties/source/properties/collected_at"
            },
            "tags": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/sourceProvenance/properties/source/properties/source_locator"
              },
              "default": []
            }
          },
          "required": [
            "schema",
            "trace",
            "recorded_at"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "provenance_id",
        "signal_id",
        "source",
        "observed_at",
        "created_at",
        "updated_at",
        "collector",
        "chain_of_custody",
        "dedupe_key",
        "audit"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
