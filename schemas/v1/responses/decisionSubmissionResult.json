{
  "$ref": "#/definitions/decisionSubmissionResult",
  "definitions": {
    "decisionSubmissionResult": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "success": {
              "type": "boolean",
              "const": true
            },
            "meta": {
              "type": "object",
              "properties": {
                "audit": {
                  "type": "object",
                  "properties": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "contractVersion": {
                          "type": "string",
                          "const": "v1"
                        },
                        "schemaName": {
                          "type": "string",
                          "minLength": 1
                        },
                        "schemaRevision": {
                          "type": "integer",
                          "minimum": 0
                        },
                        "packageVersion": {
                          "type": "string",
                          "pattern": "^\\d+\\.\\d+\\.\\d+(-[\\w.-]+)?$"
                        }
                      },
                      "required": [
                        "contractVersion",
                        "schemaName",
                        "schemaRevision",
                        "packageVersion"
                      ],
                      "additionalProperties": false
                    },
                    "trace": {
                      "type": "object",
                      "properties": {
                        "request_id": {
                          "type": "string",
                          "format": "uuid"
                        },
                        "trace_id": {
                          "type": "string",
                          "minLength": 8,
                          "maxLength": 128
                        },
                        "correlation_id": {
                          "$ref": "#/definitions/decisionSubmissionResult/anyOf/0/properties/meta/properties/audit/properties/trace/properties/request_id"
                        },
                        "actor_service": {
                          "type": "string",
                          "enum": [
                            "contracts",
                            "core",
                            "workflows",
                            "intel",
                            "console"
                          ]
                        },
                        "environment": {
                          "type": "string",
                          "enum": [
                            "local",
                            "dev",
                            "staging",
                            "production"
                          ]
                        }
                      },
                      "required": [
                        "request_id",
                        "trace_id",
                        "correlation_id",
                        "actor_service",
                        "environment"
                      ],
                      "additionalProperties": false
                    },
                    "recorded_at": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "tags": {
                      "type": "array",
                      "items": {
                        "$ref": "#/definitions/decisionSubmissionResult/anyOf/0/properties/meta/properties/audit/properties/schema/properties/schemaName"
                      },
                      "default": []
                    }
                  },
                  "required": [
                    "schema",
                    "trace",
                    "recorded_at"
                  ],
                  "additionalProperties": false
                },
                "confidence_band": {
                  "type": "string",
                  "enum": [
                    "low",
                    "guarded",
                    "elevated",
                    "confirmed"
                  ]
                },
                "warnings": {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/decisionSubmissionResult/anyOf/0/properties/meta/properties/audit/properties/schema/properties/schemaName"
                  },
                  "default": []
                }
              },
              "required": [
                "audit"
              ],
              "additionalProperties": false
            },
            "data": {
              "type": "object",
              "properties": {
                "signal_id": {
                  "$ref": "#/definitions/decisionSubmissionResult/anyOf/0/properties/meta/properties/audit/properties/trace/properties/request_id"
                },
                "submitted": {
                  "type": "boolean"
                },
                "target_service": {
                  "$ref": "#/definitions/decisionSubmissionResult/anyOf/0/properties/meta/properties/audit/properties/trace/properties/actor_service"
                },
                "target_endpoint": {
                  "$ref": "#/definitions/decisionSubmissionResult/anyOf/0/properties/meta/properties/audit/properties/schema/properties/schemaName"
                },
                "trace_id": {
                  "$ref": "#/definitions/decisionSubmissionResult/anyOf/0/properties/meta/properties/audit/properties/trace/properties/trace_id"
                },
                "correlation_id": {
                  "$ref": "#/definitions/decisionSubmissionResult/anyOf/0/properties/meta/properties/audit/properties/trace/properties/request_id"
                }
              },
              "required": [
                "signal_id",
                "submitted",
                "target_service",
                "target_endpoint",
                "trace_id",
                "correlation_id"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "success",
            "meta",
            "data"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "success": {
              "type": "boolean",
              "const": false
            },
            "meta": {
              "$ref": "#/definitions/decisionSubmissionResult/anyOf/0/properties/meta"
            },
            "error": {
              "type": "object",
              "properties": {
                "code": {
                  "$ref": "#/definitions/decisionSubmissionResult/anyOf/0/properties/meta/properties/audit/properties/schema/properties/schemaName"
                },
                "message": {
                  "$ref": "#/definitions/decisionSubmissionResult/anyOf/0/properties/meta/properties/audit/properties/schema/properties/schemaName"
                },
                "details": {
                  "type": "object",
                  "additionalProperties": {}
                },
                "trace_id": {
                  "$ref": "#/definitions/decisionSubmissionResult/anyOf/0/properties/meta/properties/audit/properties/trace/properties/trace_id"
                },
                "retryable": {
                  "type": "boolean",
                  "default": false
                }
              },
              "required": [
                "code",
                "message",
                "trace_id"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "success",
            "meta",
            "error"
          ],
          "additionalProperties": false
        }
      ]
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
