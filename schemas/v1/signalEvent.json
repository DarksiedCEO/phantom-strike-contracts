{
  "$ref": "#/definitions/signalEvent",
  "definitions": {
    "signalEvent": {
      "type": "object",
      "properties": {
        "event_id": {
          "type": "string",
          "format": "uuid"
        },
        "event_type": {
          "type": "string",
          "enum": [
            "signal.ingested",
            "signal.normalized",
            "signal.scored",
            "signal.review.requested",
            "signal.escalated"
          ]
        },
        "signal_id": {
          "$ref": "#/definitions/signalEvent/properties/event_id"
        },
        "prior_signal_status": {
          "type": "string",
          "enum": [
            "draft",
            "triaged",
            "validated",
            "escalated",
            "suppressed",
            "resolved"
          ]
        },
        "resulting_signal_status": {
          "$ref": "#/definitions/signalEvent/properties/prior_signal_status"
        },
        "workflow_disposition": {
          "type": "string",
          "enum": [
            "promote",
            "hold",
            "escalate",
            "suppress",
            "archive"
          ]
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "created_at": {
          "$ref": "#/definitions/signalEvent/properties/occurred_at"
        },
        "producer": {
          "type": "string",
          "enum": [
            "contracts",
            "core",
            "workflows",
            "intel",
            "console"
          ]
        },
        "payload_version": {
          "type": "string",
          "const": "v1"
        },
        "payload": {
          "type": "object",
          "additionalProperties": {}
        },
        "idempotency_key": {
          "type": "string",
          "minLength": 1
        },
        "audit": {
          "type": "object",
          "properties": {
            "schema": {
              "type": "object",
              "properties": {
                "contractVersion": {
                  "type": "string",
                  "const": "v1"
                },
                "schemaName": {
                  "$ref": "#/definitions/signalEvent/properties/idempotency_key"
                },
                "schemaRevision": {
                  "type": "integer",
                  "minimum": 0
                },
                "packageVersion": {
                  "type": "string",
                  "pattern": "^\\d+\\.\\d+\\.\\d+(-[\\w.-]+)?$"
                }
              },
              "required": [
                "contractVersion",
                "schemaName",
                "schemaRevision",
                "packageVersion"
              ],
              "additionalProperties": false
            },
            "trace": {
              "type": "object",
              "properties": {
                "request_id": {
                  "$ref": "#/definitions/signalEvent/properties/event_id"
                },
                "trace_id": {
                  "type": "string",
                  "minLength": 8,
                  "maxLength": 128
                },
                "correlation_id": {
                  "$ref": "#/definitions/signalEvent/properties/event_id"
                },
                "actor_service": {
                  "$ref": "#/definitions/signalEvent/properties/producer"
                },
                "environment": {
                  "type": "string",
                  "enum": [
                    "local",
                    "dev",
                    "staging",
                    "production"
                  ]
                }
              },
              "required": [
                "request_id",
                "trace_id",
                "correlation_id",
                "actor_service",
                "environment"
              ],
              "additionalProperties": false
            },
            "recorded_at": {
              "$ref": "#/definitions/signalEvent/properties/occurred_at"
            },
            "tags": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/signalEvent/properties/idempotency_key"
              },
              "default": []
            }
          },
          "required": [
            "schema",
            "trace",
            "recorded_at"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "event_id",
        "event_type",
        "signal_id",
        "occurred_at",
        "created_at",
        "producer",
        "payload_version",
        "idempotency_key",
        "audit"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
